  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "composite": true,
    "emitDeclarationOnly": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "vite.config.ts",
    "scripts/**/*.ts"
  ]
}
